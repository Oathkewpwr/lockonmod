{
	"schemaVersion": 1,
	"id": "lockonmod",
	"version": "${version}",
	"name": "Lock on",
	"description": "A Zelda-style lock-on added to Minecraft Java by Oathkewpwr.",
	"authors": [
		"Oathkewpwr!"
	],
	"contact": {
		"homepage": "https://oathkewpwr.net",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/lockonmod/icon.png",
	"environment": "*",
